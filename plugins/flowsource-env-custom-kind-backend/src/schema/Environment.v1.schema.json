{
  "$schema": "http://json-schema.org/draft-07/schema",
  "$id": "EnvironmentV1",
  "description": "An Environment describes an infrastructure for components.",
  "examples": [
    {
      "apiVersion": "flowsource/v1",
      "kind": "Environment",
      "metadata": {
        "name": "LoremService",
        "description": "Creates Lorems like a pro.",
        "labels": {
          "product_name": "Random value Generator"
        },
        "annotations": {
          "docs": "https://github.com/..../tree/develop/doc"
        }
      },
      "spec": {
        "type": "qa",
        "owner": "tools"
      }
    }
  ],
  "allOf": [
    {
      "$ref": "Entity"
    },
    {
      "type": "object",
      "required": ["spec"],
      "properties": {
        "apiVersion": {
          "enum": ["flowsource/v1"]
        },
        "kind": {
          "enum": ["Environment"]
        },
        "spec": {
          "type": "object",
          "required": ["type", "owner"],
          "properties": {
            "type": {
              "type": "string",
              "description": "The type of environment.",
              "examples": ["QA", "Dev", "Prod"],
              "minLength": 1
            },
            "owner": {
              "type": "string",
              "description": "An entity reference to the owner of the environment.",
              "examples": ["artist-relations-team", "user:john.johnson", "group:catalog-admin"],
              "minLength": 1
            },
            "system": {
              "type": "string",
              "description": "An entity reference to the system that the environment belongs to.",
              "minLength": 1
            },
            "subenvironmentOf": {
              "type": "string",
              "description": "An entity reference to another environment of which the environment is a part.",
              "minLength": 1
            },
            "dependsOn": {
              "type": "array",
              "description": "An array of references to other entities that the environment depends on to function.",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    }
  ]
}